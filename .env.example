# =============================================================================
# AgriDoctor AI - Environment configuration
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# --- Security (REQUIRED) ---
# Generate with:  python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# --- Local CNN (PRIMARY diagnosis engine) ---
# Trained by scripts/train_cnn.py. Diagnoses tomato / potato / pepper / maize
# leaves offline with no API call, and rejects non-plant photos locally.
USE_LOCAL_CNN=true
CNN_MODEL_PATH=data/models/agridoctor_cnn.pt
# Calibrated confidence (post temperature-scaling) needed to answer locally.
# Raise it to escalate more borderline cases to the cloud model; lower it to
# answer more offline at the cost of accepting weaker predictions.
CNN_CONFIDENCE_THRESHOLD=0.75
# Minimum gap between the top two classes before a prediction is trusted.
CNN_MARGIN_THRESHOLD=0.10
# Confidence needed to reject an image locally as "not a plant".
CNN_REJECT_THRESHOLD=0.60
# Average the prediction over the image and its mirror (~2x inference, still fast).
CNN_USE_TTA=true
# Attach a Grad-CAM heatmap showing which pixels drove the diagnosis.
ENABLE_GRADCAM=true

# --- Groq AI (OPTIONAL — the escalation tier) ---
# Free key from https://console.groq.com
# Only used for images the CNN declines: crops it wasn't trained on (rice, chili,
# cucumber, eggplant), livestock, and low-confidence cases. Leave blank to run
# fully offline — those cases then return an honest "not confident" result.
GROQ_API_KEY=
# Verify current model IDs at https://console.groq.com/docs/models
GROQ_VISION_MODEL=qwen/qwen3.6-27b
GROQ_AUDIO_MODEL=whisper-large-v3-turbo
GROQ_TEXT_MODEL=llama-3.3-70b-versatile

# --- AI behavior ---
AI_TIMEOUT_SECONDS=30
AI_MAX_RETRIES=2

# --- Uploads / CORS ---
MAX_UPLOAD_MB=10
# Comma-separated list of allowed browser origins (no trailing slash)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Auth ---
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- Logging ---
LOG_LEVEL=INFO
